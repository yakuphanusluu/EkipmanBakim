<Window x:Class="EkipmanBakimProjesi.BakimTakipEkrani"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bakım Takip Paneli" Height="500" Width="700" WindowStartupLocation="CenterScreen" Background="#FFF5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Bakımı Gelen ve Yaklaşan Ekipmanlar" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1" x:Name="DgBakimTakip" AutoGenerateColumns="False" IsReadOnly="True" 
                  HeadersVisibility="Column" Background="White" RowHeight="35" FontSize="14" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ekipman Numarası" Binding="{Binding EkipmanNo}" Width="150" FontWeight="Bold"/>
                <DataGridTextColumn Header="Son Bakım" Binding="{Binding SonBakim}" Width="120"/>

                <DataGridTemplateColumn Header="Sonraki Bakıma Kalan Süre" Width="175">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding KalanSureMetin}" Foreground="{Binding DurumRengi}" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Durum" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding DurumRengi}" CornerRadius="5" Padding="10,2" Margin="5,4" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Durum}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>