<Window x:Class="EkipmanBakimProjesi.GirisEkrani"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Veritabanı Bağlantısı" Icon="icon.ico" Height="500" Width="400" WindowStartupLocation="CenterScreen" Background="#FFF0F0F0">
    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="Sunucu Adı:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtSunucu" Padding="5" Margin="0,0,0,10"/>

            <TextBlock Text="Kullanıcı Adı:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtUser" Padding="5" Margin="0,0,0,10"/>

            <TextBlock Text="Şifre:" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="TxtPass" Padding="5" Margin="0,0,0,15"/>

            <Button x:Name="BtnDbGetir" Content="Veritabanlarını Getir" Padding="8" Click="BtnDbGetir_Click" Background="#FF0078D7" Foreground="White" Margin="0,0,0,20"/>

            <TextBlock Text="Veritabanı Seç:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbVeritabanlari" Padding="5" Margin="0,0,0,15" SelectionChanged="CmbVeritabanlari_SelectionChanged"/>

            <TextBlock Text="Tablo Seç:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbTablolar" Padding="5" Margin="0,0,0,25"/>

            <Button x:Name="BtnBaslat" Content="Uygulamayı Başlat" Padding="10" Click="BtnBaslat_Click" Background="#FF107C10" Foreground="White" FontWeight="Bold" FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>