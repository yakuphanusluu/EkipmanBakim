<Window x:Class="EkipmanBakimProjesi.ArizaGecmisiEkrani"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arıza Geçmişi" Height="550" Width="1100" WindowStartupLocation="CenterOwner" Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <!-- YENİ: Butonlar için satır eklendi -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🛠️ Geçmiş Arıza Kayıtları" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>

        <DataGrid Grid.Row="1" x:Name="DgArizaGecmisi" AutoGenerateColumns="False" IsReadOnly="True" 
                  HeadersVisibility="Column" Background="White" RowHeight="35" AlternatingRowBackground="#F1F5F9"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Parça / Ekipman Adı" Binding="{Binding EkipmanAdi}" Width="2.5*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="TextWrapping" Value="Wrap"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Arıza Tarihi" Binding="{Binding BildirimTarihi, StringFormat=dd.MM.yyyy HH:mm}" Width="1.5*"/>
                <DataGridTextColumn Header="Giderildiği Tarih" Binding="{Binding CozumTarihi, StringFormat=dd.MM.yyyy HH:mm}" Width="1.5*"/>

                <DataGridTextColumn Header="Toplam Arıza Süresi" Binding="{Binding ToplamSure}" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#DC2626"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- YENİ: Excel ve PDF Çıktı Butonları -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="📊 Excel'e Aktar" Click="BtnExcel_Click" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="0,0,10,0" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="📄 PDF Çıkart" Click="BtnPdf_Click" Background="#EF4444" Foreground="White" FontWeight="Bold" Padding="15,10" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>