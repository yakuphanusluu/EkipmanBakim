<Window x:Class="EkipmanBakimProjesi.MakineKullanimRaporuEkrani"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Makine Kullanım (Utilization) ve Performans Analizi" Height="750" Width="1250"
        WindowStartupLocation="CenterScreen" Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Başlangıç:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,5,0"/>
                <DatePicker x:Name="DpBaslangic" Width="130" SelectedDateChanged="Filtre_Changed"/>

                <TextBlock Text="Bitis:" VerticalAlignment="Center" FontWeight="Bold" Margin="15,0,5,0"/>
                <DatePicker x:Name="DpBitis" Width="130" SelectedDateChanged="Filtre_Changed"/>

                <Button Content="📅 Bu Ay" Click="BtnBuAy_Click" Margin="15,0,5,0" Padding="10,5" Background="#E2E8F0" BorderThickness="0"/>
                <Button Content="🔄 Tüm Zamanlar" Click="BtnTumZamanlar_Click" Margin="5,0,20,0" Padding="10,5" Background="#E2E8F0" BorderThickness="0"/>

                <Button Content="📊 Excel Raporu Çıkart" Click="BtnExcel_Click" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="15,7" BorderThickness="0" Margin="0,0,10,0"/>
                <Button Content="📑 PDF Raporu Çıkart" Click="BtnPdf_Click" Background="#EF4444" Foreground="White" FontWeight="Bold" Padding="15,7" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="📈 Makine Çalışma Süreleri Görsel Karşılaştırması (Saat)" FontWeight="Bold" FontSize="16" Foreground="#1E293B" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="IcGrafik">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding EkipmanAdi}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding EkipmanAdi}"/>

                                    <Grid Grid.Column="1" Margin="10,0">
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding UtilizationYuzdesi}" Height="22" Foreground="{Binding BarRengi}" Background="#F1F5F9" BorderThickness="0"/>
                                    </Grid>

                                    <TextBlock Grid.Column="2" Text="{Binding ToplamCalismaSaati, StringFormat={}{0:N1} Saat}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="🔥 En Çok Çalışan Makineler (Top Kullanım)" FontWeight="Bold" FontSize="15" Foreground="#047857" Margin="0,0,0,10"/>
                    <DataGrid x:Name="DgEnCokCalisanlar" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ekipman No" Binding="{Binding EkipmanNo}" Width="90"/>
                            <DataGridTextColumn Header="Makine Adı" Binding="{Binding EkipmanAdi}" Width="*"/>
                            <DataGridTextColumn Header="Toplam Saat" Binding="{Binding ToplamCalismaSaati, StringFormat={}{0:N1} sa}" Width="90"/>
                            <DataGridTextColumn Header="Utilization" Binding="{Binding UtilizationMetin}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="White" Padding="15" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="❄️ En Az Çalışan Makineler (Düşük Kullanım)" FontWeight="Bold" FontSize="15" Foreground="#B91C1C" Margin="0,0,0,10"/>
                    <DataGrid x:Name="DgEnAzCalisanlar" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ekipman No" Binding="{Binding EkipmanNo}" Width="90"/>
                            <DataGridTextColumn Header="Makine Adı" Binding="{Binding EkipmanAdi}" Width="*"/>
                            <DataGridTextColumn Header="Toplam Saat" Binding="{Binding ToplamCalismaSaati, StringFormat={}{0:N1} sa}" Width="90"/>
                            <DataGridTextColumn Header="Utilization" Binding="{Binding UtilizationMetin}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>