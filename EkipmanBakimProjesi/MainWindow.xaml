<Window x:Class="EkipmanBakimProjesi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ekipman Bakım ve Çalışma Takip" Icon="icon.ico" Height="650" Width="1100" WindowStartupLocation="CenterScreen" Background="#FFF5F5F5" Activated="Window_Activated">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button x:Name="BtnGeri" Content="⬅ Geri" Width="75" Padding="8" Margin="0,0,20,0" Click="BtnGeri_Click" Background="#FF5C5C5C" Foreground="White" FontWeight="Bold" Cursor="Hand" ToolTip="Giriş Ekranına Dön">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            <TextBlock Text="Ekipman Seç:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" FontSize="14"/>
            <ComboBox x:Name="CmbEkipmanlar" Width="220" Margin="0,0,25,0" Padding="5"/>
            <TextBlock Text="Başlangıç:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" FontSize="14"/>
            <DatePicker x:Name="DpBaslangic" Width="130" Margin="0,0,20,0"/>
            <TextBlock Text="Bitiş:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" FontSize="14"/>
            <DatePicker x:Name="DpBitis" Width="130" Margin="0,0,15,0"/>
            
            <Button x:Name="BtnTarihiTemizle" Content="Temizle" Width="70" Padding="8" Margin="0,0,10,0" Click="BtnTarihiTemizle_Click" Background="#FF757575" Foreground="White" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <Button x:Name="BtnFiltrele" Content="Kayıtları Getir" Width="120" Padding="8" Click="BtnFiltrele_Click" Background="#FF0078D7" Foreground="White" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="DgKayitlar" AutoGenerateColumns="False" IsReadOnly="True" 
                  AlternatingRowBackground="#FFE6F0FA" HeadersVisibility="Column" Background="White" RowHeight="30" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ekipman Numarası" Binding="{Binding Equipment}" Width="140"/>
                <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                <DataGridTextColumn Header="Çalışma Saati" Binding="{Binding WorkingHours}" Width="120"/>
                <DataGridTextColumn Header="Ekipman Adı" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,15,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="DgCalisilmayanGunler" AutoGenerateColumns="False" IsReadOnly="True" 
              HeadersVisibility="Column" Background="White" RowHeight="25" MaxHeight="120" Margin="0,0,15,0"
              AlternatingRowBackground="#FFFFE5E5" BorderBrush="#FFD83B01" BorderThickness="1" Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Çalışılmayan Tarihler" Binding="{Binding StringFormat={}{0:dd.MM.yyyy}}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="10" Padding="15" BorderBrush="#E1E1E1" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="TxtToplamSaat" Text="Toplam Çalışma Saati: 0" FontSize="16" FontWeight="Bold" Foreground="#FF107C10" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtCalisilmayanGunlerOzet" Text="Çalışılmayan Günler: (Ekipman seçildiğinde hesaplanacak)" FontSize="12" Foreground="#FFD83B01" Margin="0,0,0,15" TextWrapping="Wrap"/>
                    <Separator Margin="0,0,0,15" Background="#E1E1E1"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="SON BAKIM" Foreground="#6C757D" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtSonBakimTarihi" Text="--.--.----" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="KALAN SÜRE" Foreground="#6C757D" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtBakimKalanSure" Text="Veri Bekleniyor" FontSize="14" FontWeight="Bold" Foreground="#007BFF"/>
                            <TextBlock x:Name="TxtTahminiTarihAna" Text="Tahmini: --" FontSize="11" Foreground="#8E44AD" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="10,20,10,10" VerticalAlignment="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                <Button Content="Arıza Geçmişi" Click="BtnArizaGecmisi_Click" Background="#475569" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    </Button>

                    <Button Content="Arıza Bildir" Click="BtnArizaBildir_Click" Background="#DC2626" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Ürün/Parça Talep" Click="BtnUrunTalep_Click" Background="#06B6D4" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Geçmiş Bakımlar" Click="BtnGecmis_Click" Background="#374151" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Bakım Takip Tablosu" Click="BtnTakip_Click" Background="#F59E0B" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Bakım Yönetimi" Click="BtnBakim_Click" Background="#10B981" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Grafik Göster" Click="BtnGrafik_Click" Background="#8B5CF6" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Makine Kullanım Raporu" Click="BtnUtilization_Click" Background="#3B82F6" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="📊 Excel'e Aktar" Click="BtnExcel_Click" Background="#059669" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="📄 Rapor Çıkart (PDF)" Click="BtnPdf_Click" Background="#DC2626" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="5">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Grid>
    </Grid>
</Window>