<Window x:Class="EkipmanBakimProjesi.BakimDetayiEkrani"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bakım Detayı" Height="450" Width="400" WindowStartupLocation="CenterScreen" Background="#FFF5F5F5" WindowStyle="ToolWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Bakım Raporu" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ekipman Numarası:" FontWeight="Bold" Foreground="#555" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtEkipmanNo" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Son Bakım Tarihi:" FontWeight="Bold" Foreground="#555" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtTarih" Foreground="#333" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Bakımı Yapan:" FontWeight="Bold" Foreground="#555" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtKisi" Foreground="#333" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Bakım Periyodu:" FontWeight="Bold" Foreground="#555"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtPeriyot" Foreground="#333"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFF9C4" BorderBrush="#F1C40F" BorderThickness="1" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Bakım Detayı:" FontWeight="Bold" Foreground="#D35400" Margin="0,0,0,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtAciklama" TextWrapping="Wrap" Foreground="#444" FontSize="14" LineHeight="20"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Button Grid.Row="3" Content="Kapat" Background="#95A5A6" Foreground="White" FontWeight="Bold" FontSize="14" Height="35" Margin="0,15,0,0" Click="BtnKapat_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>