<Window x:Class="EkipmanBakimProjesi.ArizaBildirimEkrani"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🚨 Arıza Bildirim Ekranı" Height="400" Width="500" 
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Makinada Arıza Bildir" FontSize="22" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Arızalı Ekipmanı Seçin:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbEkipmanlar" Height="35" FontSize="14" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Arıza Açıklaması / Detayı:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtArizaAciklamasi" TextWrapping="Wrap" AcceptsReturn="True" Height="100" Padding="5" FontSize="14"/>
        </StackPanel>

        <Button Grid.Row="3" Content="Arızayı Sisteme Kaydet" Click="BtnKaydet_Click" Background="#DC2626" Foreground="White" FontWeight="Bold" Height="45" FontSize="16">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>